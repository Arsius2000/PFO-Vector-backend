                },
                "phone_number": {
                    "type": "string"
                },
                "rating": {
                    "description": "Если nil -\u003e БД поставит 0",
                    "type": "integer"
                },
                "study_group": {
                    "type": "string"
                },
                "telegram": {
                    "description": "Обязательно (NOT NULL в БД)",
                    "type": "string"
                },
                "telegram_id": {
                    "description": "UNIQUE в БД",
                    "type": "integer"
                },
                "visited_events_count": {
                    "description": "Если nil -\u003e БД поставит 0",
                    "type": "integer"
                }
            }
        },
